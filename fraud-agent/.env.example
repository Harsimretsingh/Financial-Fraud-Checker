# OpenAI-compatible API (OpenAI, OpenRouter, Azure OpenAI, LM Studio, etc.)
LLM_API_KEY=your_api_key_here
# Optional — defaults to https://api.openai.com/v1
# LLM_BASE_URL=https://api.openai.com/v1
# Optional model IDs (defaults shown)
# LLM_MODEL_FAST=gpt-4o-mini
# LLM_MODEL_REASONING=gpt-4o

# Stripe webhook collection (test/live)
# From Stripe CLI: stripe listen --forward-to localhost:3001/stripe/webhook
# Or Dashboard webhook signing secret (endpoint: /stripe/webhook)
STRIPE_SECRET_KEY=sk_test_or_sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret_here

SPECTER_API_KEY=your_specter_key_here
PORT=3001
